{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Dufus Inbox Watcher",
            "type": "shell",
            "command": "node",
            "args": [
                "${workspaceFolder}/.vscode/dufus-watcher.js"
            ],
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "showReuseMessage": false,
                "close": false
            },
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
